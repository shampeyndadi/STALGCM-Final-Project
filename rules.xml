<?xml version="1.0" encoding="UTF-8"?>

<rules lang="tl">
  <category id="MCO2_FILIPINO_SPELLING" name="Filipino Spelling 1">
        <rule id="ET_IT" name="ET(IT)">
            <pattern case_sensitive="no">
                <token regexp="yes">.*et$ <exception regexp="yes">dyaket|tiket|porket|pinakbet|pakbet</exception></token>
            </pattern>

            <message>Do you mean <suggestion><match no="1" regexp_match="(.*)et$" regexp_replace="$1it"/></suggestion>?</message>
            <short>Sound and Letter Change</short>

            <example correction="sakit" type="incorrect">Ang tiyan ko ay <marker>masaket</marker>.</example>
            <example type="correct">Ang tiyan ko ay <marker>masakit</marker>.</example>
            <example correction="mabait" type="incorrect">Talagang <marker>mabaet</marker> siyang bata.</example>
            <example type="correct">Talagang <marker>mabait</marker> siyang bata.</example>
            <example correction="bakit" type="incorrect"><marker>Baket</marker> hindi ka sumama?</example>
            <example type="correct"><marker>Bakit</marker> hindi ka sumama?</example>
            <example correction="pangit" type="incorrect">Hindi naman siya <marker>panget</marker>.</example>
            <example type="correct">Hindi naman siya <marker>pangit</marker>.</example>
            <example correction="ulit" type="incorrect">Gawin mo <marker>ulet</marker> ang activity.</example>
            <example type="correct">Gawin mo <marker>ulit</marker> ang activity.</example>
            <example correction="ulit" type="incorrect">Subukan mo <marker>ulet</marker> mamaya.</example>
            <example type="correct">Subukan mo <marker>ulit</marker> mamaya.</example>
            <example correction="sulit" type="incorrect"><marker>Sulet</marker> ang binili kong produkto.</example>
            <example type="correct"><marker>Sulit</marker> ang binili kong produkto.</example>
            <example correction="liit" type="incorrect">Ang <marker>liet</marker> ng bahay nila.</example>
            <example type="correct">Ang <marker>liit</marker> ng bahay nila.</example>
            <example correction="init" type="incorrect">Ang <marker>inet</marker> ng panahon ngayon.</example>
            <example type="correct">Ang <marker>init</marker> ng panahon ngayon.</example>
        </rule>
		
		
		<!-- Formal Rule is (Ce -> Ci) -->
        <rule id="E" name="e(i)">
            <pattern case_sensitive="no">
                <token regexp="yes">.*[^aeiou]e$<exception regexp="yes">kalye|pwede|libre|kape|karne|kotse|swerte|peste|atake|klase|base|norte|tsokolate|estante|verde|libre|kamote</exception></token>
            </pattern>
            
			<message>Do you mean <suggestion><match no="1" case_conversion="startlower" regexp_match="e$" regexp_replace="i"/></suggestion>?</message>
			<short>Sound and Letter Change</short>

			<example correction="bumili" type="incorrect">Doon ka <marker>bumile</marker>.</example>
			<example type="correct">doon ka <marker>bumili</marker>.</example>
			<example correction="nabili" type="incorrect"><marker>Nabile</marker> mo na ba?</example>
			<example type="correct"><marker>Nabili</marker> mo na ba?</example>
			<example correction="pabili" type="incorrect"><marker>Pabile</marker> dyan.</example>
			<example type="correct"><marker>Pabili</marker> dyan.</example>
			<example correction="binili" type="incorrect">Kanina ko pa <marker>binile</marker>.</example>
			<example type="correct">Kanina ko pa <marker>binili</marker>.</example>
			<example correction="kiniliti" type="incorrect">Bakit mo siya <marker>kinilite</marker>?</example>
			<example type="correct">Bakit mo siya <marker>kumiliti</marker>?</example>
			<example correction="kiliti" type="incorrect">May <marker>kilite</marker> sa lalamunan ko.</example>
			<example type="correct">May <marker>kiliti</marker> sa lalamunan ko.</example>
			<example correction="kumiliti" type="incorrect">May <marker>kumilite</marker> sa akin.</example>
			<example type="correct">May <marker>kumiliti</marker> sa akin.</example>
			<example correction="nawili" type="incorrect"><marker>Nawile</marker> ako dyan.</example>
			<example type="correct"><marker>Nawili</marker> ako dyan.</example>
			<example correction="mawili" type="incorrect">Baka <marker>mawile</marker> ka.</example>
			<example type="correct">Baka <marker>mawili</marker> ka.</example>
        </rule>

	  	<rule id="AI" name="ai(ay)">
            <pattern case_sensitive="no">
                <token regexp="yes">.*[bcdfghjklmnpqrstvwxyz]ai$<exception regexp="yes">shanghai|siomai|chai|acai|gai</exception></token>
            </pattern>
            
            <message>Do you mean <suggestion><match no="1" case_conversion="startlower" regexp_match="i$" regexp_replace="y"/></suggestion>?</message>
            <short>Sound and Letter Change</short>
            
            <example correction="tambay" type="incorrect">Tara <marker>tambai</marker> tayo sa labas mamaya.</example>
            <example type="correct">Tara <marker>tambay</marker> tayo sa labas mamaya.</example>
            <example correction="sanay" type="incorrect">Hindi pa ako <marker>sanai</marker> sa ginagawa natin.</example>
            <example type="correct">Hindi pa ako <marker>sanay</marker> sa ginagawa natin.</example>
            <example correction="patay" type="incorrect"><marker>Patai</marker> ako sa exam bukas.</example>
            <example type="correct"><marker>Patay</marker> ako sa exam bukas.</example>
        </rule>
    </category>
</rules>
